# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit .env และห้ามใส่ค่าจริงลงในไฟล์ตัวอย่างนี้ (เคยมี webhook จริงหลุดมาแล้ว — AUDIT.md H1)

# --- AI ---
# Claude Haiku 4.5 — ใช้เป็นหลักสำหรับ AI Advisor / บทวิเคราะห์ / slip OCR
ANTHROPIC_API_KEY=
# Groq llama-3.3-70b — fallback ฟรี ใช้อัตโนมัติเมื่อไม่มี ANTHROPIC_API_KEY
GROQ_API_KEY=

# --- แจ้งเตือน ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- แหล่งข้อมูล ---
FRED_API_KEY=
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=VaultisBot/1.0

# --- ระบบ ---
# PostgreSQL สำหรับ sentiment + screener history (เว้นว่าง = ข้ามฟีเจอร์นี้)
DATABASE_URL=
# URL ของ backend ที่ dashboard/jobs เรียกใช้
BACKEND_URL=http://localhost:8000

# --- ความปลอดภัยของ backend ---
# ถ้า deploy backend ขึ้นเน็ต **ต้องตั้ง** — endpoint ที่เปลี่ยนข้อมูล/เรียก LLM
# จะต้องส่ง header X-API-Key ให้ตรงกับค่านี้ (ไม่ตั้ง = รับเฉพาะคำขอจาก localhost)
VAULTIS_API_KEY=
# origin ที่อนุญาตให้เบราว์เซอร์เรียก API (คั่นด้วย ,) — ว่าง = localhost:8501 เท่านั้น
VAULTIS_ALLOWED_ORIGINS=
